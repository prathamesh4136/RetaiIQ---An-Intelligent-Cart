# =========================
# Backend Uploads (RetailIQ Specific)
# =========================
# Ignores locally uploaded shop logos and product images 
# so you don't push dummy/test images to GitHub.
uploads/*
public/uploads/*
# (Optional) keep the empty directory structure by not ignoring a .gitkeep file
!uploads/.gitkeep
!public/uploads/.gitkeep

